{
  "name": "oh-my-experiments",
  "version": "0.3.0",
  "description": "Experiment-analysis & design harness for RL/ML research. Analyze training runs, diagnose regressions, design the next experiment, and run a semi-autonomous analyze-design-eval loop. Self-contained: an omx CLI over .omx/ JSON state, with zero runtime dependency on other harnesses.",
  "author": {
    "name": "luckkim123"
  },
  "repository": "https://github.com/luckkim123/oh-my-experiments",
  "homepage": "https://github.com/luckkim123/oh-my-experiments",
  "license": "MIT",
  "keywords": [
    "claude-code",
    "plugin",
    "experiment-analysis",
    "rl",
    "ml-research",
    "harness"
  ],
  "skills": [
    "./skills/exp-init/",
    "./skills/exp-analyze/",
    "./skills/exp-design/",
    "./skills/exp-loop/"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/run_hook.py", "report_guard"]
          }
        ]
      }
    ]
  }
}
